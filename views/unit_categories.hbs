<div class="container mt-4">
    <h2 class="mb-4">Categorias de Medida</h2>
    <div class="row" id="categoriasGrid">
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-weight-hanging fa-3x mb-3 text-primary"></i>
                    <h5 class="card-title">Peso</h5>
                    <p class="card-text text-muted">Gramas, Quilos, Toneladas</p>
                    <button class="btn btn-primary w-100" onclick="navegarParaItens('peso')">Ver itens</button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-ruler-combined fa-3x mb-3 text-success"></i>
                    <h5 class="card-title">Metro</h5>
                    <p class="card-text text-muted">Centímetros, Metros, Km</p>
                    <button class="btn btn-success w-100" onclick="navegarParaItens('metro')">Ver itens</button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-box fa-3x mb-3 text-warning"></i>
                    <h5 class="card-title">Unidade</h5>
                    <p class="card-text text-muted">Peças, Caixas, Pacotes</p>
                    <button class="btn btn-warning w-100" onclick="navegarParaItens('unidade')">Ver itens</button>
                </div>
            </div>
        </div>
    </div>
</div>